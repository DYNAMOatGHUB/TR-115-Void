[Unit]
Description=Carbon Intelligence Consumer Service
After=network.target kafka.target carbon-producer.service

[Service]
Type=simple
User=ghostofsparta
WorkingDirectory=/home/ghostofsparta/cd_key_Projects/project
Environment="PATH=/home/ghostofsparta/cd_key_Projects/project/.venv/bin"
EnvironmentFile=/home/ghostofsparta/cd_key_Projects/project/.env
ExecStart=/home/ghostofsparta/cd_key_Projects/project/.venv/bin/python consumer.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=carbon-consumer

[Install]
WantedBy=multi-user.target
